{
  "name": "synalux-local-relay",
  "version": "1.0.0",
  "description": "Generic local network proxy for Synalux cloud apps",
  "main": "server.mjs",
  "type": "module",
  "bin": "server.mjs",
  "scripts": {
    "start": "node server.mjs",
    "build": "npx @yao-pkg/pkg server.mjs --output dist/synalux-local-relay"
  },
  "pkg": {
    "targets": ["node18"],
    "outputPath": "dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "bonjour-service": "^1.4.0",
    "dotenv": "^17.4.2"
  }
}
